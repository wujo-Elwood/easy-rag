<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rag.mapper.FeedbackMapper">

    <insert id="insert" parameterType="com.rag.entity.Feedback" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_feedback (message_id, helpful, create_time)
        VALUES (#{messageId}, #{helpful}, NOW())
    </insert>

</mapper>
